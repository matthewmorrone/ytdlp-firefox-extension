{
  "manifest_version": 2,
  "name": "yt-dlp launcher",
  "version": "0.4.0",
  "description": "Download the current tab's media with yt-dlp.",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg",
    "128": "icon.svg"
  },
  "background": {
    "scripts": ["capture.js", "background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_title": "yt-dlp",
    "default_popup": "popup.html",
    "default_icon": "icon-action.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ytdlp@matthewmorrone",
      "strict_min_version": "109.0"
    }
  }
}
