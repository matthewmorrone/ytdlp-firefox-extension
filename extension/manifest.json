{
  "manifest_version": 3,
  "name": "yt-dlp launcher",
  "version": "0.3.0",
  "description": "Download the current tab's media with yt-dlp.",
  "permissions": ["nativeMessaging", "activeTab", "storage", "tabs"],
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg",
    "128": "icon.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "yt-dlp",
    "default_popup": "popup.html",
    "default_icon": "icon-action.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ytdlp@matthewmorrone",
      "strict_min_version": "115.0"
    }
  }
}
